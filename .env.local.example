# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=                  # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=                     # same as NEXT_PUBLIC_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=        # Settings → API → service_role key

# OpenAI — https://platform.openai.com/
OPENAI_API_KEY=

# Vercel Blob — auto-set when using `vercel env pull`
BLOB_READ_WRITE_TOKEN=

# Meta Conversions API — https://business.facebook.com/
NEXT_PUBLIC_META_PIXEL_ID=26490568997297314
META_ACCESS_TOKEN=

# Stripe — https://dashboard.stripe.com/
STRIPE_SECRET_KEY=                # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=            # whsec_... from webhook endpoint
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (create products in Stripe Dashboard, copy price IDs)
STRIPE_PRICE_MONTHLY=             # price_... for $5/mo subscription (30 scans)
STRIPE_PRICE_YEARLY=              # price_... for $39/yr subscription (30 scans/mo)
STRIPE_PRICE_TOPUP=               # price_... for $5 one-time top-up (50 scans)
